{
  "name": "explain-my-error",
  "version": "1.0.5",
  "description": "AI-powered CLI to explain programming errors with fixes and ELI5 output.",
  "type": "module",
  "bin": {
    "explain-my-error": "./dist/cli.js",
    "eme": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@10.30.3",
  "files": ["dist", "skills/SKILL.md", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "release": "node scripts/release.mjs patch",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "prepare": "pnpm run build"
  },
  "keywords": ["cli", "errors", "debugging", "ai", "groq", "agent-skill"],
  "author": "Awais Ali",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awaisaly/explain-my-error.git"
  },
  "homepage": "https://github.com/awaisaly/explain-my-error#readme",
  "bugs": {
    "url": "https://github.com/awaisaly/explain-my-error/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "tsup": "^8.3.5",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
